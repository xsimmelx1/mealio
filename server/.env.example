# Mealio Server — Beispiel-Umgebung. Kopiere zu `.env` (wird NICHT committet).

# Port des Backends
PORT=8787

# Erlaubte Frontend-Origin(s) für CORS (kommagetrennt).
# APP_ORIGIN hat Vorrang; CORS_ORIGIN bleibt als Alias erhalten.
APP_ORIGIN=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# --- LLM (ab Milestone 9) ---
# Anbieter frei wählbar; Aufruf gekapselt im llmClient-Modul (austauschbar).
# Default-Adapter: Google Gemini (kostenloser Free-Tier).
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gemini-1.5-flash

# --- Externe Datenquellen (ab Milestone 10/11) ---
# Nährwerte: lokaler Seed ist Primärquelle (offline). Online nur opt-in.
# NUTRITION_ONLINE=1 aktiviert ergänzende Live-Lookups (USDA -> Open Food Facts).
NUTRITION_ONLINE=0
# USDA FoodData Central API-Key (Public Domain Daten). Ohne Key wird "DEMO_KEY"
# (stark rate-limitiert) genutzt. https://fdc.nal.usda.gov/api-key-signup.html
FDC_API_KEY=DEMO_KEY
# Preise: Manual > LocalSeed > Online (das Frontend entscheidet die Priorität).
# Der Server liefert nur den Online-Adapter. PRICES_ONLINE=1 aktiviert opt-in
# Live-Lookups gegen Open Food Facts "Open Prices" (ODbL, Attribution + Share-Alike).
# Ohne Flag liefert /prices sofort source:"unknown" (App-Flow wird nie blockiert).
PRICES_ONLINE=0
