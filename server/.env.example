# Mealio Server — Beispiel-Umgebung. Kopiere zu `.env` (wird NICHT committet).

# Port des Backends
PORT=8787

# Erlaubte Frontend-Origin(s) für CORS (kommagetrennt).
# APP_ORIGIN hat Vorrang; CORS_ORIGIN bleibt als Alias erhalten.
APP_ORIGIN=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# --- LLM (ab Milestone 9) ---
# Anbieter frei wählbar; Aufruf gekapselt im llmClient-Modul (austauschbar).
# Default-Adapter: Google Gemini (kostenloser Free-Tier).
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gemini-1.5-flash

# --- Externe Datenquellen (ab Milestone 10/11) ---
# USDA FoodData Central API-Key (Public Domain Daten). https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=
# Online-Preise (Open Food Facts "Open Prices") — opt-in Feature-Flag
ENABLE_ONLINE_PRICES=false
